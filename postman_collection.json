  },
  "item": [
    {
      "name": "Generate Certificate",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\",\n  \"date\": \"2026-04-11\",\n  \"purpose\": \"Completion of Advanced Node.js Course\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/generate-certificate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "generate-certificate"
          ]
        },
        "description": "Generates an IBM Distribution Sector certificate PNG image.\n\nRequired fields:\n- name: Recipient's full name (2-100 characters)\n- date: Certificate date in ISO 8601 format (YYYY-MM-DD)\n- purpose: Purpose or achievement description (5-500 characters)\n\nThe API returns a PNG image that can be saved or displayed."
      },
      "response": []
    },
